{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Compass",
  "version": "0.4.0",
  "identifier": "com.compass.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Compass",
        "width": 1600,
        "height": 1000,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI4NjI1ODc2NDk1ODEyODgKUldTSUVsaEpkbGhpdU0zeE1tUzhNRkVKQmlrNXp4VjZNQktwMTZtQ0xoK2lsVWdMZ1JoOVRmZzcK",
      "endpoints": [
        "https://github.com/__REPO__/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp"
      },
      "wix": {
        "upgradeCode": "6c5b4a3d-2e1f-4a9b-9c7d-6e5f4a3b2c1d",
        "bannerPath": "icons/installer-wix-banner.bmp",
        "dialogImagePath": "icons/installer-wix-dialog.bmp"
      }
    }
  }
}
